{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DaedalusIsoformPairRecord",
  "type": "object",
  "required": [
    "gene_id",
    "reference_isoform_id",
    "alternative_isoform_id",
    "species",
    "transcript_delta",
    "protein_delta",
    "labels",
    "sources"
  ],
  "properties": {
    "gene_id": { "type": "string" },
    "reference_isoform_id": { "type": "string" },
    "alternative_isoform_id": { "type": "string" },
    "species": { "type": "string" },
    "transcript_delta": {
      "type": "object",
      "properties": {
        "frameshift": { "type": "boolean" },
        "junction_delta_count": { "type": "integer" },
        "exon_insertions": { "type": "integer" },
        "exon_deletions": { "type": "integer" },
        "utr_delta": { "type": "boolean" }
      },
      "required": ["frameshift", "junction_delta_count", "exon_insertions", "exon_deletions", "utr_delta"]
    },
    "protein_delta": {
      "type": "object",
      "properties": {
        "orf_length_ref": { "type": "integer" },
        "orf_length_alt": { "type": "integer" },
        "nmd_like": { "type": "boolean" },
        "domain_loss_count": { "type": "integer" },
        "domain_gain_count": { "type": "integer" },
        "tm_helix_delta": { "type": "integer" },
        "signal_peptide_changed": { "type": "boolean" }
      },
      "required": [
        "orf_length_ref",
        "orf_length_alt",
        "nmd_like",
        "domain_loss_count",
        "domain_gain_count",
        "tm_helix_delta",
        "signal_peptide_changed"
      ]
    },
    "family_flags": {
      "type": "object",
      "properties": {
        "is_membrane_protein": { "type": "boolean" },
        "is_kinase": { "type": "boolean" },
        "is_transcription_factor": { "type": "boolean" }
      }
    },
    "labels": {
      "type": "object",
      "properties": {
        "functional_preservation": { "type": ["number", "null"] },
        "deviation_class": { "type": ["string", "null"] },
        "surface_retained": { "type": ["boolean", "null"] },
        "kinase_competent": { "type": ["boolean", "null"] },
        "tf_competent": { "type": ["boolean", "null"] }
      }
    },
    "sources": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
