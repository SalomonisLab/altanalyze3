Bootstrap: docker
From: nvidia/cuda:12.4.1-cudnn-runtime-ubuntu22.04

%files
    Daedalus/container/requirements.txt /opt/daedalus-requirements.txt

%environment
    export LC_ALL=C.UTF-8
    export LANG=C.UTF-8
    export PYTHONDONTWRITEBYTECODE=1
    export PYTHONUNBUFFERED=1

%post
    apt-get update
    apt-get install -y --no-install-recommends \
        bash \
        build-essential \
        ca-certificates \
        curl \
        git \
        python3 \
        python3-dev \
        python3-pip \
        python3-venv \
        unzip
    rm -rf /var/lib/apt/lists/*
    ln -sf /usr/bin/python3 /usr/bin/python
    python -m pip install --upgrade pip setuptools wheel
    python -m pip install --extra-index-url https://download.pytorch.org/whl/cu124 -r /opt/daedalus-requirements.txt

%runscript
    exec /bin/bash "$@"

%labels
    Author saljh8
    Project Daedalus
    Purpose Reference-conditioned isoform function modeling environment
