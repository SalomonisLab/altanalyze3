**/.DS_Store

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
temp
.tox/
.coverage
.coverage.*
cov.xml
.cache
nosetests.xml
coverage.xml
*,cover
.hypothesis/
cromwell-executions
cromwell-workflow-logs
_codex_archive/
.codex_archive/

# IDE
.vscode
jobs/
.venv/

# fastComm training/download outputs
altanalyze3/components/fastComm/artifacts/
altanalyze3/components/fastComm/cache/
altanalyze3/components/fastComm/training_data/
altanalyze3/components/fastComm/benchmarks/
altanalyze3/components/fastComm/models/

# Per-component artifacts/ folders. Each component owns a single artifacts/
# directory used for intermediate benchmark outputs, scratch evaluation
# TSVs, trained-bundle scratch space, etc. Not tracked.
altanalyze3/components/*/artifacts/

# rna2adt: trained bundle bytes (~190 KB to ~55 MB each, many variants) are
# regenerable from training scripts. Track adt_rna_map.py / build_whitelist.py
# / configs/*.tsv; ignore the .pkl bundles and per-ADT metrics TSVs.
altanalyze3/components/rna2adt/*.pkl
altanalyze3/components/rna2adt/mouse/*.pkl
altanalyze3/components/rna2adt/mouse/rna2adt_mm_per_adt_metrics.tsv

# rna2lipid: same pattern (large pickled bundles regenerable from training).
altanalyze3/components/rna2lipid/*.pkl

# cellHarmony web app — per-user runtime job state. The local jobs/ tree
# can grow to many GB of test runs; never belongs in version control.
# (Repeats the broader 'jobs/' rule above for clarity.)
altanalyze3/components/cellHarmony/webapp/jobs/

# Daedalus training outputs — per-phase checkpoints, downloaded data,
# saved models, and run logs. data/ is ignored only under Daedalus
# (other components have small tracked reference data we want kept).
altanalyze3/components/Daedalus/phase_*/checkpoints/
altanalyze3/components/Daedalus/phase_*/data/
altanalyze3/components/Daedalus/phase_*/models/
altanalyze3/components/Daedalus/phase_*/logs/
altanalyze3/components/Daedalus/phase_*/lightning_logs/
altanalyze3/components/Daedalus/phase_*/wandb/

# Proteus large pretraining corpora.
altanalyze3/components/Proteus/data/

# Miscellaneous scratch / runtime
altanalyze3/components/tests/logs/
tmp/
*.swp
# Ad-hoc tmp_* outputs (e.g. marker-heatmap test runs in cellHarmony/flask).
# Anything intentionally tracked should be renamed without the tmp_ prefix.
tmp_*
**/tmp_*

# Per-edit working backups created automatically by Claude. Each edit produces
# a timestamped copy under .edit-archive/<YYYYMMDD>/<HHMMSS>__<filename> with a
# matching log entry in .edit-archive/edits.log. Not tracked.
.edit-archive/
